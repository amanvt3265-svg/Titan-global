# ─────────────────────────────────────────────────────────────
# Titan Global Transport — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# ─────────────────────────────────────────────────────────────

# SMTP account used to SEND the emails (the "from" mailbox).
# For Gmail, create an App Password: https://myaccount.google.com/apppasswords
EMAIL_USER=your-mailbox@gmail.com
EMAIL_PASS=your-app-password

# Where contact + quote submissions are delivered.
# Optional — defaults to company.contactReceiver in src/config/company.ts
# (dispatch@titanglobal.co.nz). Set here only to override per-environment.
CONTACT_RECEIVER=dispatch@titanglobal.co.nz

# Optional — override SMTP transport (defaults to Gmail service).
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_SECURE=false

# Public site URL (used for canonical + Open Graph URLs).
NEXT_PUBLIC_SITE_URL=https://www.titanglobaltransport.co.nz

# ─────────────────────────────────────────────────────────────
# Spam / bot protection — Cloudflare Turnstile (optional).
# When BOTH keys are set, the contact + quote forms render a
# Turnstile challenge and the server verifies the token before
# sending. Leave blank to disable (forms still work locally).
# Get keys: https://dash.cloudflare.com/?to=/:account/turnstile
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
